{
  "name": "quill",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun ./public/index.html",
    "build": "bun build ./public/index.html --outdir dist",
    "test": "bun test",
    "check": "biome check --write .",
    "check:ci": "biome check . && tsc --noEmit && bun test",
    "format": "biome format --write .",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-push": "bun run check:ci"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "^1.3.14",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^7.0.2"
  }
}
